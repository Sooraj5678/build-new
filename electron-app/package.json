{
  "name": "vyapar-outstanding-formatter",
  "version": "1.0.0",
  "description": "Convert Vyapar Outstanding Excel exports into professional city-wise printable reports",
  "author": {
    "name": "Vyapar Outstanding Formatter",
    "email": ""
  },
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k -n VITE,ELECTRON -c cyan,yellow \"vite\" \"wait-on tcp:5173 && electron .\"",
    "build": "vite build",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win --x64",
    "dist:dir": "npm run build && electron-builder --dir"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.17.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^33.3.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.47",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "wait-on": "^8.0.0",
    "xlsx": "^0.18.5"
  },
  "build": {
    "extends": null,
    "appId": "com.vyapar.outstanding-formatter",
    "productName": "Vyapar Outstanding Formatter",
    "copyright": "Copyright © 2024",
    "directories": {
      "output": "dist-installer",
      "buildResources": "build"
    },
    "files": [
      "dist/**",
      "electron/**",
      "package.json"
    ],
    "extraResources": [],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "VyaparOutstandingFormatter-${version}-Setup.exe"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Vyapar Outstanding Formatter",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "deleteAppDataOnUninstall": false
    },
    "publish": {
      "provider": "github",
      "releaseType": "release"
    }
  }
}
